figdown 0.1 bitfield
# Hardware control register — single 32-bit word, lsb0 numbering (ruler 31..0)
title Control Register Pattern

bitfield ctrl_reg "Control Register" unit=32
# Row 0: flag cluster at high bits + wide mode field + small type nibble + reserved low bits
field Reserved 4
field TYPE 4
field FIELD_A 8
field MODE 6
field Reserved 6
field FLAG_C:1, FLAG_B:1, FLAG_A:1, EN:1
